<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">
    <changeSet id="add-receiver-column" author="mean">
        <!-- add status_id -->
        <addColumn tableName="borrowings">
            <column name="receiver_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="add-key" author="">
        <addForeignKeyConstraint
                baseTableName="borrowings"
                baseColumnNames="receiver_id"
                referencedTableName="authorizers"
                referencedColumnNames="id"
                constraintName="fk_returns_receiver"
                onDelete="SET NULL"/>
    </changeSet>
</databaseChangeLog>