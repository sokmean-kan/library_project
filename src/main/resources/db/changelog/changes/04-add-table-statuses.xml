<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="9" author="dev">
        <createSequence sequenceName="borrow_statuses_id_seq" startValue="1" incrementBy="1"/>
        <createTable tableName="borrow_statuses">
            <column name="id" type="BIGINT" defaultValueSequenceNext="borrow_statuses_id_seq">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(20)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="10" author="dev">
        <insert tableName="borrow_statuses">
            <column name="name" value="PENDING"/>
        </insert>
        <insert tableName="borrow_statuses">
            <column name="name" value="APPROVED"/>
        </insert>
        <insert tableName="borrow_statuses">
            <column name="name" value="RETURNED"/>
        </insert>
        <insert tableName="borrow_statuses">
            <column name="name" value="OVERDUE"/>
        </insert>
    </changeSet>

    <changeSet id="update-status-type" author="mean">
            <modifyDataType
                    tableName="borrow_statuses"
                    columnName="id"
                    newDataType="INT"/>
    </changeSet>
</databaseChangeLog>