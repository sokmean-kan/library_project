<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">


    <changeSet id="1" author="dev">
        <createSequence sequenceName="categories_id_seq" startValue="1" incrementBy="20"/>
        <createTable tableName="categories">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="dev">
        <createSequence sequenceName="books_id_seq" startValue="1" incrementBy="50"/>
        <createTable tableName="books">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="author" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="isbn" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="stock" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="category_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
                baseTableName="books"
                baseColumnNames="category_id"
                referencedTableName="categories"
                referencedColumnNames="id"
                constraintName="fk_books_category"
                onDelete="RESTRICT"/>

    </changeSet>
    <changeSet id="3" author="dev">
        <createSequence sequenceName="members_id_seq" startValue="1" incrementBy="10"/>
        <createTable tableName="members">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="phone" type="VARCHAR(20)"/>
            <column name="address" type="TEXT"/>
            <column name="joined_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="4" author="dev">
        <createSequence sequenceName="borrowings_id_seq" startValue="1" incrementBy="10"/>
        <createTable tableName="borrowings">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="member_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="book_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="borrowed_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="due_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="returned_at" type="TIMESTAMP"/>
            <column name="fine" type="DECIMAL(10,2)" defaultValueNumeric="0"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="borrowings"
                baseColumnNames="member_id"
                referencedTableName="members"
                referencedColumnNames="id"
                constraintName="fk_borrowings_member"
                onDelete="RESTRICT"/>

        <addForeignKeyConstraint
                baseTableName="borrowings"
                baseColumnNames="book_id"
                referencedTableName="books"
                referencedColumnNames="id"
                constraintName="fk_borrowings_book"
                onDelete="RESTRICT"/>

    </changeSet>
</databaseChangeLog>

